---
import { solutions } from '../data/solutions.js';
const featured = solutions.slice(0, 6);
---
<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/logo.svg" alt="CrewTEC" width="72" height="44" style="object-fit:contain" />
      <p>System integrator delivering enterprise IT solutions across India.</p>
      <p class="footer-address">No. 10/11, Maragondanahalli Tavarekere,<br/>Bangalore – 562130, Karnataka</p>
    </div>
    <div class="footer-col">
      <h4>Solutions</h4>
      <ul>
        {featured.map(s => (
          <li><a href={`/solutions/${s.id}`}>{s.name}</a></li>
        ))}
        <li><a href="/">View all 17 →</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        <li><a href="mailto:sales@crewtec.in">sales@crewtec.in</a></li>
        <li><a href="tel:+919986437648">+91 99864 37648</a></li>
        <li><a href="https://wa.me/919986437648" target="_blank" rel="noopener">WhatsApp Us</a></li>
        <li><a href="/contact">Get a Quote</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} CrewTEC. All rights reserved.</p>
    <p>Bangalore, Karnataka, India</p>
  </div>
</footer>

<!-- WhatsApp FAB -->
<a class="wa-fab" href="https://wa.me/919986437648" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
  </svg>
</a>

<style>
footer {
  background: var(--navy);
  padding: 56px 0 24px;
  color: rgba(255,255,255,0.55);
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 40px;
}
.footer-brand img { filter: brightness(1.3); margin-bottom: 14px; }
.footer-brand p { font-size: 0.875rem; line-height: 1.7; max-width: 280px; }
.footer-address { margin-top: 10px; font-size: 0.8rem; color: rgba(255,255,255,0.4); }

.footer-col h4 {
  font-family: 'Syne', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.9);
  margin-bottom: 16px;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-col a {
  color: rgba(255,255,255,0.5);
  font-size: 0.875rem;
  transition: color 0.2s;
}
.footer-col a:hover { color: var(--blue-light); }

.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px 24px 0;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}
.footer-bottom p { font-size: 0.78rem; }

/* WhatsApp FAB */
.wa-fab {
  position: fixed;
  bottom: 24px; right: 24px;
  width: 52px; height: 52px;
  background: #25D366;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(37,211,102,0.4);
  z-index: 999;
  transition: transform 0.2s, box-shadow 0.2s;
}
.wa-fab:hover { transform: scale(1.08); box-shadow: 0 8px 24px rgba(37,211,102,0.5); }

@media (max-width: 768px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 480px) {
  .footer-inner { grid-template-columns: 1fr; }
}
</style>
