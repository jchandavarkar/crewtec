---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { solutions, colorMap, LOGO_DEV_TOKEN } from '../data/solutions.js';

const masonry = [
  { id: 'firewall-solutions' },
  { id: 'encryption-solutions' },
  { id: 'data-loss-prevention' },
  { id: 'soc-solutions' },
  { id: 'hsm-solutions' },
  { id: 'identity-solutions' },
  { id: 'zero-trust-solutions' },
  { id: 'mobile-security-solutions' },
  { id: 'email-security' },
  { id: 'network-security' },
  { id: 'application-infrastructure' },
  { id: 'alm-solutions' },
  { id: 'hybrid-cloud-solutions' },
  { id: 'endpoint-security' },
  { id: 'data-forensic-solutions' },
  { id: 'hardware-supply' },
  { id: 'professional-services' },
];

function getLogoUrl(domain) {
  return `https://img.logo.dev/${domain}?token=${LOGO_DEV_TOKEN}&size=80&format=webp`;
}
---

<BaseLayout
  title="IT Solutions Bangalore | System Integrator"
  description="CrewTEC is Bangalore's authorised iValue partner delivering enterprise cybersecurity, cloud, and IT infrastructure solutions. Explore 15 solution categories and 50+ global brands."
  canonical="/"
>
  <Header />

  <main>
    <!-- HERO BANNER -->
    <section class="page-hero">
      <div class="hero-inner">

        <!-- Logo + tagline -->
        <div class="hero-brand">
          <img src="/logo.svg" alt="CrewTEC" class="hero-logo" />
          <div class="hero-text">
            <h1 class="hero-tagline">Empowering Enterprises with <span>Next-Gen IT</span></h1>
            <p class="hero-sub">25+ years of IT & cybersecurity expertise · Trusted by 500+ enterprises · Bangalore-based, Pan-India delivery</p>
            <a href="#solutions" class="hero-cta">Explore Solutions ↓</a>
          </div>
        </div>

        <!-- Trust stats strip -->
        <div class="trust-strip">
          <div class="trust-item">
            <span class="trust-num">25+</span>
            <span class="trust-label">Years Experience</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <span class="trust-num">500+</span>
            <span class="trust-label">Enterprise Clients</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <span class="trust-num">50+</span>
            <span class="trust-label">Global Brands</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <span class="trust-num">15+</span>
            <span class="trust-label">Solution Categories</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <span class="trust-num">PAN</span>
            <span class="trust-label">India Delivery</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <span class="trust-num">24/7</span>
            <span class="trust-label">Support</span>
          </div>
        </div>

      </div>
    </section>

    <!-- GRID LABEL -->
    <div class="grid-label">
      <div class="grid-label-inner">
        <span>Browse Solutions</span>
        <span class="grid-label-count">15 categories · click any to explore</span>
      </div>
    </div>

    <section class="grid-section" id="solutions">
      <div class="masonry-grid">
        {masonry.map(({ id }) => {
          const sol = solutions.find(s => s.id === id);
          if (!sol) return null;
          const colors = colorMap[sol.color];
          const topBrands = sol.brands.slice(0, 3);
          return (
            <a href={`/solutions/${sol.id}`} class="card" style={`--card-bg:${colors.bg};--card-text:${colors.text};--card-border:${colors.border}`}>
              <div class="card-top">
                <div class="card-icon-wrap" style={`background:${colors.bg};border-color:${colors.border}`}>
                  <span class="card-emoji">{sol.icon}</span>
                </div>
                <span class="card-number">0{sol.number.replace('0','')}</span>
              </div>
              <h2 class="card-name">{sol.name}</h2>
              <p class="card-desc">{sol.shortDesc}</p>
              <div class="card-logos">
                {topBrands.map(brand => (
                  <div class="brand-item">
                    <div class="brand-logo-wrap">
                      <img
                        src={getLogoUrl(brand.domain)}
                        alt={brand.name}
                        width="56"
                        height="56"
                        loading="lazy"
                        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                      />
                      <span class="brand-fallback" style={`background:${colors.bg};color:${colors.text};display:none`}>
                        {brand.name.slice(0,2).toUpperCase()}
                      </span>
                    </div>
                    <span class="brand-label">{brand.name}</span>
                  </div>
                ))}
                {sol.brands.length > 3 && (
                  <div class="brand-item">
                    <div class="brand-more-wrap" style={`background:${colors.bg};border-color:${colors.border}`}>
                      <span style={`color:${colors.text}`}>+{sol.brands.length - 3}</span>
                    </div>
                    <span class="brand-label">more</span>
                  </div>
                )}
              </div>
              <div class="card-arrow" style={`color:${colors.text}`}>
                Explore →
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
/* ── HERO ── */
.page-hero {
  background: var(--navy);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  position: relative;
  overflow: hidden;
}
.page-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,153,238,0.07) 1px, transparent 1px);
  background-size: 44px 44px;
  pointer-events: none;
}
.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  position: relative;
  z-index: 1;
}

/* Logo + tagline row */
.hero-brand {
  display: flex;
  align-items: center;
  gap: 48px;
  padding: 48px 0 36px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.hero-logo {
  width: 180px;
  height: auto;
  flex-shrink: 0;
  filter: drop-shadow(0 0 24px rgba(30,180,231,0.25));
}
.hero-text { flex: 1; }
.hero-tagline {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 12px;
}
.hero-tagline span { color: #1EB4E7; }
.hero-sub {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.45);
  margin-bottom: 20px;
  line-height: 1.6;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 24px;
  background: #0099EE;
  color: #fff;
  border-radius: var(--radius);
  font-size: 0.9rem;
  font-weight: 600;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 0 4px 16px rgba(0,153,238,0.35);
}
.hero-cta:hover { background: var(--blue-dark); transform: translateY(-2px); }

/* Trust strip */
.trust-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 0;
  gap: 8px;
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  flex: 1;
}
.trust-num {
  font-family: 'Syne', sans-serif;
  font-size: 1.8rem;
  font-weight: 800;
  color: #1EB4E7;
  line-height: 1;
}
.trust-label {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.45);
  text-align: center;
  letter-spacing: 0.04em;
  line-height: 1.3;
}
.trust-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}

/* Grid label bar */
.grid-label {
  background: var(--offwhite);
  border-bottom: 1.5px solid var(--border);
  padding: 12px 24px;
}
.grid-label-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.grid-label span {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.grid-label-count {
  font-size: 0.78rem;
  color: var(--muted) !important;
  font-weight: 400 !important;
  text-transform: none !important;
  letter-spacing: 0 !important;
}

/* Responsive */
@media (max-width: 768px) {
  .hero-brand { flex-direction: column; align-items: flex-start; gap: 24px; padding: 32px 0 24px; }
  .hero-logo { width: 130px; }
  .trust-strip { flex-wrap: wrap; gap: 16px; padding: 20px 0; }
  .trust-divider { display: none; }
  .trust-item { flex: 0 0 30%; }
}

/* ── GRID ── */
.grid-section {
  background: var(--offwhite);
  padding: 32px 24px 56px;
}

.masonry-grid {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 280px;
  gap: 16px;
}

/* ── CARD ── */
.card {
  background: var(--white);
  border: 1.5px solid var(--card-border, var(--border));
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s;
  cursor: pointer;
  color: inherit;
  position: relative;
  overflow: hidden;
}
.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--card-text, var(--blue));
  opacity: 0;
  transition: opacity 0.25s;
}
.card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--card-text, var(--blue));
}
.card:hover::before { opacity: 1; }



/* ── CARD CONTENTS ── */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 2px;
}
.card-icon-wrap {
  width: 36px; height: 36px;
  border-radius: 9px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-emoji { font-size: 1.1rem; }
.card-number {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--card-text, var(--blue));
  opacity: 0.7;
}
.card-name {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.2;
}
.card-desc {
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── BRAND LOGOS ── */
.card-logos {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-top: auto;
  flex-wrap: wrap;
}
.brand-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}
.brand-logo-wrap {
  width: 56px; height: 56px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.brand-logo-wrap img {
  width: 48px; height: 48px;
  object-fit: contain;
  padding: 4px;
}
.brand-fallback {
  width: 100%; height: 100%;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 9px;
}
.brand-label {
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--muted);
  text-align: center;
  max-width: 56px;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.brand-more-wrap {
  width: 56px; height: 56px;
  border-radius: 10px;
  border: 1.5px dashed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: 700;
}

.card-arrow {
  font-size: 0.8rem;
  font-weight: 600;
  margin-top: 4px;
  opacity: 0;
  transition: opacity 0.2s;
}
.card:hover .card-arrow { opacity: 1; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .masonry-grid { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 280px; }
}
@media (max-width: 768px) {
  .masonry-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 260px;
    gap: 12px;
  }
  .card { min-height: 260px; }
}
@media (max-width: 480px) {
  .masonry-grid { grid-template-columns: 1fr; }
  .grid-section { padding: 20px 16px 40px; }
}
</style>
