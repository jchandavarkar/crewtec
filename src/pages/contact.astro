---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
---
<BaseLayout
  title="Contact Us | Get a Quote"
  description="Contact CrewTEC for enterprise IT solutions in Bangalore. Get a free consultation on cybersecurity, cloud, and infrastructure solutions powered by iValue."
  canonical="/contact"
>
  <Header />
  <main>
    <section class="contact-hero">
      <div class="contact-hero-inner">
        <h1>Let's Find the Right Solution for You</h1>
        <p>Fill in the form and a CrewTEC specialist will reach out within 24 hours.</p>
      </div>
    </section>
    <section class="contact-body">
      <div class="contact-inner">
        <div class="contact-info">
          <h2>Get in Touch</h2>
          <p>We're headquartered in Bangalore and serve enterprises across India as an authorised iValue partner.</p>
          <div class="contact-items">
            <div class="contact-item">
              <div class="ci-icon">📧</div>
              <div>
                <strong>Email</strong>
                <a href="mailto:sales@crewtec.in">sales@crewtec.in</a>
              </div>
            </div>
            <div class="contact-item">
              <div class="ci-icon">📞</div>
              <div>
                <strong>Phone</strong>
                <a href="tel:+919986437648">+91 99864 37648</a>
              </div>
            </div>
            <div class="contact-item">
              <div class="ci-icon">📍</div>
              <div>
                <strong>Office</strong>
                <span>No. 10/11, Maragondanahalli Tavarekere,<br/>Bangalore – 562130, Karnataka</span>
              </div>
            </div>
            <div class="contact-item">
              <div class="ci-icon">💬</div>
              <div>
                <strong>WhatsApp</strong>
                <a href="https://wa.me/919986437648" target="_blank" rel="noopener">Message us on WhatsApp</a>
              </div>
            </div>
          </div>
        </div>
        <QuoteForm />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
.contact-hero {
  background: var(--navy);
  padding: 48px 0;
  text-align: center;
}
.contact-hero-inner { max-width: 600px; margin: 0 auto; padding: 0 24px; }
.contact-hero h1 { color: #fff; font-size: clamp(1.6rem, 4vw, 2.4rem); margin-bottom: 12px; }
.contact-hero p { color: rgba(255,255,255,0.55); margin: 0; }

.contact-body { background: var(--offwhite); padding: 56px 0 80px; }
.contact-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 56px;
  align-items: start;
}
.contact-info h2 { color: var(--navy); margin-bottom: 12px; font-size: 1.5rem; }
.contact-info > p { margin-bottom: 32px; }
.contact-items { display: flex; flex-direction: column; gap: 20px; }
.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.ci-icon {
  width: 42px; height: 42px;
  min-width: 42px;
  background: var(--blue-pale);
  border-radius: 11px;
  border: 1px solid rgba(0,153,238,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
}
.contact-item strong { display: block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 3px; }
.contact-item a, .contact-item span { font-size: 0.95rem; color: var(--text); font-weight: 500; }
.contact-item a { color: var(--blue); }
.contact-item a:hover { color: var(--blue-dark); }

@media (max-width: 900px) {
  .contact-inner { grid-template-columns: 1fr; gap: 36px; }
}
</style>
