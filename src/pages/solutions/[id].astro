---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { solutions, colorMap, LOGO_DEV_TOKEN } from '../../data/solutions.js';

export async function getStaticPaths() {
  return solutions.map(s => ({
    params: { id: s.id },
    props: { solution: s },
  }));
}

const { solution: sol } = Astro.props;
const colors = colorMap[sol.color];

function getLogoUrl(domain) {
  return `https://img.logo.dev/${domain}?token=${LOGO_DEV_TOKEN}&size=120&format=webp`;
}

const related = solutions.filter(s => s.id !== sol.id).slice(0, 3);
---

<BaseLayout
  title={sol.name}
  description={sol.metaDesc}
  canonical={`/solutions/${sol.id}`}
>
  <Header backLink={true} />

  <main>
    <!-- HERO -->
    <section class="cat-hero">
      <div class="cat-hero-inner">
        <div class="hero-content">
          <div class="hero-left">
            <span class="sol-tag">Solution {sol.number}</span>
            <h1>{sol.name}</h1>
            <p class="hero-desc">{sol.fullDesc}</p>
            <a href="#quote" class="hero-cta">Request a Quote →</a>
          </div>
          <div class="hero-icon-wrap" style={`background:${colors.bg};border-color:${colors.border}`}>
            <span class="hero-emoji">{sol.icon}</span>
          </div>
        </div>
      </div>
    </section>

    <div class="page-body">
      <div class="page-body-inner">

        <!-- LEFT COLUMN -->
        <div class="content-col">

          <!-- BRANDS with inline expand -->
          <section class="content-section">
            <h2 class="section-title" style={`color:${colors.text}`}>Key Vendors & Brands</h2>
            <p class="section-hint">Click any brand to see product details</p>
            <div class="brands-list" id="brandsList">
              {sol.brands.map((brand, idx) => (
                <div class="brand-row-wrap">
                  <div
                    class="brand-card"
                    data-idx={String(idx)}
                    role="button"
                    tabindex="0"
                  >
                    <div class="brand-logo-wrap">
                      <img
                        src={getLogoUrl(brand.domain)}
                        alt={`${brand.name} logo`}
                        width="80"
                        height="80"
                        loading="lazy"
                        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                      />
                      <span class="brand-fallback" style={`background:${colors.bg};color:${colors.text};display:none`}>
                        {brand.name.slice(0,2).toUpperCase()}
                      </span>
                    </div>
                    <div class="brand-info">
                      <span class="brand-name">{brand.name}</span>
                      <span class="brand-type">{brand.type}</span>
                    </div>
                    <div class="brand-toggle" style={`color:${colors.text}`}>
                      <span class="toggle-icon">＋</span>
                      <span class="toggle-label">View details</span>
                    </div>
                  </div>

                  <!-- INLINE EXPAND PANEL -->
                  <div class="brand-detail" id={`detail-${idx}`} style={`border-color:${colors.border}`}>
                    <div class="detail-inner">

                      <div class="detail-header" style={`background:${colors.bg}`}>
                        <div class="detail-logo-wrap">
                          <img
                            src={getLogoUrl(brand.domain)}
                            alt={brand.name}
                            width="80"
                            height="80"
                            loading="lazy"
                            onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                          />
                          <span class="brand-fallback-lg" style={`background:${colors.border};color:${colors.text};display:none`}>
                            {brand.name.slice(0,2).toUpperCase()}
                          </span>
                        </div>
                        <div>
                          <h3 class="detail-name">{brand.name}</h3>
                          <span class="detail-type" style={`color:${colors.text}`}>{brand.type}</span>
                          <p class="detail-overview">{brand.overview}</p>
                        </div>
                      </div>

                      <div class="detail-body">
                        <div class="detail-cols">

                          <div class="detail-col">
                            <h4 class="detail-col-title" style={`color:${colors.text}`}>Key Features</h4>
                            <ul class="detail-list feature-list">
                              {brand.features.map(f => (
                                <li>
                                  <span class="list-dot" style={`background:${colors.text}`}></span>
                                  {f}
                                </li>
                              ))}
                            </ul>
                          </div>

                          <div class="detail-col">
                            <h4 class="detail-col-title" style={`color:${colors.text}`}>Use Cases</h4>
                            <ul class="detail-list use-list">
                              {brand.useCases.map(u => (
                                <li>
                                  <span class="list-check" style={`color:${colors.text}`}>✓</span>
                                  {u}
                                </li>
                              ))}
                            </ul>
                          </div>

                        </div>

                        <div class="why-crewtec" style={`border-left-color:${colors.text}`}>
                          <span class="why-label" style={`color:${colors.text}`}>Why CrewTEC recommends {brand.name}</span>
                          <p>{brand.whyCrewtec}</p>
                        </div>

                        <div class="detail-cta">
                          <p>Interested in <strong>{brand.name}</strong>? Talk to our specialists for a free consultation.</p>
                          <a href="/contact" class="detail-cta-btn" style={`background:${colors.text}`}>
                            Get a Quote for {brand.name} →
                          </a>
                        </div>

                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- USE CASES -->
          <section class="content-section">
            <h2 class="section-title" style={`color:${colors.text}`}>What We Help You Achieve</h2>
            <ul class="check-list">
              {sol.useCases.map(uc => (
                <li>
                  <span class="check" style={`background:${colors.bg};color:${colors.text}`}>✓</span>
                  {uc}
                </li>
              ))}
            </ul>
          </section>

          <!-- FEATURES -->
          <section class="content-section">
            <h2 class="section-title" style={`color:${colors.text}`}>Key Features</h2>
            <div class="features-grid">
              {sol.features.map(f => (
                <div class="feature-item" style={`border-left-color:${colors.text}`}>
                  <p>{f}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- RELATED -->
          <section class="content-section">
            <h2 class="section-title" style={`color:${colors.text}`}>Related Solutions</h2>
            <div class="related-grid">
              {related.map(r => {
                const rc = colorMap[r.color];
                return (
                  <a href={`/solutions/${r.id}`} class="related-card">
                    <span class="related-icon" style={`background:${rc.bg}`}>{r.icon}</span>
                    <div>
                      <span class="related-name">{r.name}</span>
                      <span class="related-desc">{r.shortDesc}</span>
                    </div>
                    <span class="related-arrow">→</span>
                  </a>
                );
              })}
            </div>
          </section>

        </div>

        <!-- RIGHT COLUMN — STICKY QUOTE FORM -->
        <aside class="form-col" id="quote">
          <div class="form-sticky">
            <div class="form-cta-banner" style={`background:${colors.bg};border-color:${colors.border}`}>
              <p style={`color:${colors.text}`}>Interested in <strong>{sol.name}</strong>? Talk to our specialists.</p>
            </div>
            <QuoteForm prefill={sol.id} />
            <div class="contact-strip">
              <a href="tel:+919986437648">📞 +91 99864 37648</a>
              <a href="mailto:sales@crewtec.in">✉️ sales@crewtec.in</a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
/* HERO */
.cat-hero {
  background: var(--navy);
  padding: 48px 0;
  position: relative;
  overflow: hidden;
}
.cat-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(0,153,238,0.08) 1px, transparent 1px);
  background-size: 40px 40px;
}
.cat-hero-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.hero-content { display: flex; align-items: center; justify-content: space-between; gap: 40px; }
.hero-left { flex: 1; }
.sol-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue-light); margin-bottom: 12px; opacity: 0.8; }
.hero-left h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); color: #fff; margin-bottom: 16px; }
.hero-desc { color: rgba(255,255,255,0.6); font-size: 1rem; max-width: 540px; margin-bottom: 28px; }
.hero-cta { display: inline-flex; align-items: center; padding: 13px 24px; background: var(--blue); color: #fff; border-radius: var(--radius); font-weight: 600; font-size: 0.95rem; transition: background 0.2s, transform 0.2s; box-shadow: 0 4px 16px rgba(0,153,238,0.35); }
.hero-cta:hover { background: var(--blue-dark); transform: translateY(-2px); }
.hero-icon-wrap { width: 100px; height: 100px; border-radius: 24px; border: 2px solid; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hero-emoji { font-size: 3rem; }

/* PAGE BODY */
.page-body { background: var(--offwhite); padding: 48px 0 64px; }
.page-body-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: start; }

/* SECTION */
.content-section { margin-bottom: 40px; }
.section-title { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
.section-hint { font-size: 0.8rem; color: var(--muted); margin-bottom: 14px; }

/* BRAND ROWS */
.brands-list { display: flex; flex-direction: column; gap: 0; }
.brand-row-wrap { border: 1.5px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; background: var(--white); transition: box-shadow 0.2s; }
.brand-row-wrap:hover { box-shadow: var(--shadow); }
.brand-row-wrap.open { box-shadow: var(--shadow-lg); }

.brand-card {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 18px;
  cursor: pointer;
  user-select: none;
  transition: background 0.2s;
}
.brand-card:hover { background: var(--offwhite); }

.brand-logo-wrap {
  width: 80px; height: 80px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
}
.brand-logo-wrap img { width: 68px; height: 68px; object-fit: contain; padding: 6px; }
.brand-fallback { width: 100%; height: 100%; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; border-radius: 9px; }

.brand-info { flex: 1; }
.brand-name { display: block; font-size: 1rem; font-weight: 600; color: var(--navy); margin-bottom: 3px; }
.brand-type { font-size: 0.8rem; color: var(--muted); }

.brand-toggle { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 600; flex-shrink: 0; transition: opacity 0.2s; }
.toggle-icon { font-size: 1.2rem; font-weight: 400; line-height: 1; transition: transform 0.3s; }
.brand-row-wrap.open .toggle-icon { transform: rotate(45deg); }
.brand-row-wrap.open .toggle-label { display: none; }

/* INLINE DETAIL PANEL */
.brand-detail {
  display: none;
  border-top: 2px solid;
}
.brand-row-wrap.open .brand-detail { display: block; }

.detail-inner { }

.detail-header {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  padding: 20px 20px 16px;
}
.detail-logo-wrap {
  width: 80px; height: 80px;
  min-width: 80px;
  border-radius: 14px;
  border: 1px solid rgba(0,0,0,0.08);
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-logo-wrap img { width: 68px; height: 68px; object-fit: contain; padding: 6px; }
.brand-fallback-lg { width: 100%; height: 100%; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; border-radius: 13px; }

.detail-name { font-family: 'Syne', sans-serif; font-size: 1.15rem; color: var(--navy); margin-bottom: 3px; }
.detail-type { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px; }
.detail-overview { font-size: 0.875rem; color: var(--muted); line-height: 1.65; margin: 0; }

.detail-body { padding: 0 20px 20px; }

.detail-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 16px; margin-top: 16px; }
.detail-col-title { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }

.detail-list { list-style: none; display: flex; flex-direction: column; gap: 7px; }
.detail-list li { display: flex; align-items: flex-start; gap: 8px; font-size: 0.85rem; color: var(--text); line-height: 1.5; }
.list-dot { width: 6px; height: 6px; min-width: 6px; border-radius: 50%; margin-top: 6px; }
.list-check { font-size: 0.75rem; font-weight: 700; margin-top: 1px; flex-shrink: 0; }

.why-crewtec {
  background: var(--offwhite);
  border-left: 3px solid;
  border-radius: 0 var(--radius) var(--radius) 0;
  padding: 14px 16px;
  margin-bottom: 16px;
}
.why-label { display: block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 6px; }
.why-crewtec p { font-size: 0.875rem; color: var(--text); margin: 0; line-height: 1.6; }

.detail-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 18px;
}
.detail-cta p { font-size: 0.875rem; color: var(--text); margin: 0; }
.detail-cta strong { color: var(--navy); }
.detail-cta-btn {
  padding: 10px 20px;
  color: #fff;
  border-radius: var(--radius);
  font-size: 0.85rem;
  font-weight: 600;
  white-space: nowrap;
  transition: opacity 0.2s, transform 0.2s;
}
.detail-cta-btn:hover { opacity: 0.88; transform: translateY(-1px); }

/* USE CASES */
.check-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.check-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.9rem; color: var(--text); line-height: 1.5; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px; }
.check { width: 22px; height: 22px; min-width: 22px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; }

/* FEATURES */
.features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.feature-item { background: var(--white); border: 1px solid var(--border); border-left: 3px solid; border-radius: 0 var(--radius) var(--radius) 0; padding: 14px 16px; }
.feature-item p { font-size: 0.875rem; color: var(--text); margin: 0; }

/* RELATED */
.related-grid { display: flex; flex-direction: column; gap: 8px; }
.related-card { display: flex; align-items: center; gap: 14px; background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 14px 16px; transition: all 0.2s; color: inherit; }
.related-card:hover { border-color: var(--blue); transform: translateX(4px); }
.related-icon { font-size: 1.4rem; flex-shrink: 0; padding: 6px; border-radius: 8px; }
.related-name { display: block; font-size: 0.9rem; font-weight: 600; color: var(--navy); }
.related-desc { display: block; font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
.related-arrow { margin-left: auto; color: var(--blue); font-size: 1rem; }

/* FORM */
.form-col { }
.form-sticky { position: sticky; top: 80px; }
.form-cta-banner { border: 1px solid; border-radius: var(--radius); padding: 12px 16px; margin-bottom: 14px; }
.form-cta-banner p { font-size: 0.875rem; margin: 0; }
.contact-strip { display: flex; flex-direction: column; gap: 8px; margin-top: 14px; padding: 14px 16px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); }
.contact-strip a { font-size: 0.85rem; color: var(--blue); font-weight: 500; transition: color 0.2s; }
.contact-strip a:hover { color: var(--blue-dark); }

/* RESPONSIVE */
@media (max-width: 1024px) {
  .page-body-inner { grid-template-columns: 1fr; }
  .form-sticky { position: static; }
  .hero-icon-wrap { display: none; }
  .features-grid { grid-template-columns: 1fr; }
  .detail-cols { grid-template-columns: 1fr; gap: 12px; }
}
@media (max-width: 600px) {
  .cat-hero { padding: 32px 0; }
  .detail-header { flex-direction: column; gap: 12px; }
  .detail-cta { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
// Attach click and keyboard handlers to all brand cards
document.querySelectorAll('.brand-card').forEach(card => {
  function toggle() {
    const wrap = card.closest('.brand-row-wrap');
    if (!wrap) return;
    const isOpen = wrap.classList.contains('open');

    // Close all open panels
    document.querySelectorAll('.brand-row-wrap.open').forEach(el => el.classList.remove('open'));

    // Open clicked one if it was closed
    if (!isOpen) {
      wrap.classList.add('open');
      setTimeout(() => {
        wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 80);
    }
  }

  card.addEventListener('click', toggle);
  card.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      toggle();
    }
  });
});
</script>
